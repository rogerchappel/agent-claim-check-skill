{
  "name": "agent-claim-check-skill",
  "version": "0.1.0",
  "description": "Local-first agent skill for checking generated claims against supplied source bundles.",
  "type": "module",
  "bin": {
    "agent-claim-check": "./bin/agent-claim-check.js"
  },
  "scripts": {
    "check": "node scripts/check.js",
    "lint": "node scripts/check.js",
    "test": "node --test",
    "smoke": "node bin/agent-claim-check.js --draft fixtures/draft.md --sources fixtures/sources.json --format markdown",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "claim-checking",
    "content-review",
    "local-first"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "src",
    "fixtures",
    "docs",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/agent-claim-check-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/agent-claim-check-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/agent-claim-check-skill#readme"
}
